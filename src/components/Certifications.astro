---
const EDUCATION = [
	{
		institution: 'IronHack',
		title: 'Web Development',
		date: { es: 'ago. 2025 – feb. 2026', en: 'Aug. 2025 – Feb. 2026' },
		description: {
			es: 'Bootcamp intensivo de desarrollo full-stack con el stack MERN (MongoDB, Express, React, Node.js).',
			en: 'Intensive full-stack development bootcamp using the MERN stack (MongoDB, Express, React, Node.js).',
		},
	},
	{
		institution: 'IBM / Coursera',
		title: 'IBM RAG and Agentic AI Specialization',
		date: { es: 'mar. 2026', en: 'Mar. 2026' },
	},
	{
		institution: 'IBM SkillsBuild',
		title: 'Python Full Stack',
		date: { es: 'ago. 2023', en: 'Aug. 2023' },
	},
	{
		institution: 'Google / Coursera',
		title: 'Google IT Automation with Python',
		date: { es: 'abr. 2023', en: 'Apr. 2023' },
	},
	{
		institution: 'Assembler Institute of Technology',
		title: 'Executive DevOps Program',
		date: { es: 'mar. 2022 – jul. 2022', en: 'Mar. 2022 – Jul. 2022' },
		description: {
			es: 'Programa ejecutivo centrado en cultura DevOps y automatización de pipelines con CI/CD, contenerización con Docker, administración de sistemas Linux y orquestación de builds con Jenkins.',
			en: 'Executive program focused on DevOps culture and pipeline automation with CI/CD, containerization with Docker, Linux system administration, and build orchestration with Jenkins.',
		},
	},
	{
		institution: 'SION Certifications S.L.',
		title: 'Pentester in Ethical Hacking — Lead Auditor Certified',
		date: { es: 'nov. 2017', en: 'Nov. 2017' },
	},
	{
		institution: 'Udacity / Accenture',
		title: 'Front End Web Developer — Nanodegree',
	},
	{
		institution: 'Udacity / Accenture',
		title: 'React — Nanodegree',
	},
	{
		institution: 'Udacity / Accenture',
		title: 'Generative AI — Nanodegree',
	},
	{
		institution: 'Udacity / Accenture',
		title: 'Data Structures and Algorithms — Nanodegree',
	},
	{
		institution: 'Udacity / Accenture',
		title: 'Go Language (Golang)',
	},
	{
		institution: 'codewithmosh.com',
		title: 'The Ultimate Docker Course',
	},
	{
		institution: 'codewithmosh.com',
		title: 'Django from Zero to Hero',
	},
]
---

<ol class="relative border-s border-gray-200 dark:border-gray-700">
	{
		EDUCATION.map((item) => (
			<li class="mb-8 ms-4">
				<div class="absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -start-1.5 border border-white dark:border-gray-900 dark:bg-gray-700" />
				{item.date && (
					<time
						class="mb-1 text-xs font-normal text-gray-500"
						data-i18n-es={item.date.es}
						data-i18n-en={item.date.en}
					>
						{item.date.es}
					</time>
				)}
				<p class="mb-1 text-sm font-normal leading-none text-sky-200/80">
					{item.institution}
				</p>
				<h4 class="text-lg font-semibold text-white mt-1">{item.title}</h4>
				{item.description && (
					<p
						class="text-base font-normal text-gray-400 text-balance"
						data-i18n-es={item.description.es}
						data-i18n-en={item.description.en}
					>
						{item.description.es}
					</p>
				)}
			</li>
		))
	}
</ol>
