---
import ExperienceItem from './ExperienceItem.astro'

const EXPERIENCE = [
	{
		date: { es: 'Junio 2023 - Agosto 2024', en: 'June 2023 - August 2024' },
		title: { es: 'Desarrollador Backend con Django | RAG con langchain', en: 'Backend Developer with Django | RAG with langchain' },
		description: {
			es: 'Fundador y desarrollador de backend de una app de fútbol en una startup (QuizAndGuide).',
			en: 'Founder and backend developer of a football app at a startup (QuizAndGuide).',
		},
		link: '#',
	},
]
---

<ol class="relative border-s border-gray-200 dark:border-gray-700">
	{
		EXPERIENCE.map((experience) => (
			<ExperienceItem {...experience} />
		))
	}
</ol>
