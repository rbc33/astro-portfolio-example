---
import ExperienceItem from './ExperienceItem.astro'

const EXPERIENCE = [
	{
		date: { es: 'Junio 2023', en: 'June 2023' },
		title: { es: 'Desarrollador Backend con Django | RAG con langchain', en: 'Backend Developer with Django | RAG with langchain' },
		description: {
			es: 'Fundador y desarrollador backend de una app de fútbol en una startup (QuizAndGuide). Implementé pipelines de IA con RAG usando LangChain para responder preguntas sobre partidos y estadísticas en lenguaje natural.',
			en: 'Founder and backend developer of a football app at a startup (QuizAndGuide). Built AI pipelines with RAG using LangChain to answer questions about matches and statistics in natural language.',
		},
		link: '#',
	},
]
---

<ol class="relative border-s border-gray-200 dark:border-gray-700">
	{
		EXPERIENCE.map((experience) => (
			<ExperienceItem {...experience} />
		))
	}
</ol>
