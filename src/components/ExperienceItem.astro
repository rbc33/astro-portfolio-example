---
interface Props {
	date: { es: string; en: string }
	title: { es: string; en: string }
	description: { es: string; en: string }
	link?: string
}
const { date, title, description, link }: Props = Astro.props
---

<li class="mb-10 ms-4">
	<div
		class="absolute w-3 h-3 bg-white/20 rounded-full mt-1.5 -start-1.5 border border-white/10"
	>
	</div>
	<time
		class="mb-1 text-sm font-normal leading-none text-white/40"
		data-i18n-es={date.es}
		data-i18n-en={date.en}
	>{date.es}</time
	>
	<h3
		class="text-lg font-semibold text-white mt-2"
		data-i18n-es={title.es}
		data-i18n-en={title.en}
	>
		{title.es}
	</h3>
	<p
		class="mb-4 text-base font-normal text-white/60 text-balance"
		data-i18n-es={description.es}
		data-i18n-en={description.en}
	>
		{description.es}
	</p>
	{
		link && link !== '#' && (
			<a
				href={link}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 text-sm font-medium text-white/70
					hover:text-white border-b border-white/20 hover:border-white/50 transition-all duration-200 pb-0.5"
			>
				<span data-i18n-es="Saber más" data-i18n-en="Learn more">Saber más</span>
				<svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
					<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9" />
				</svg>
			</a>
		)
	}
</li>
